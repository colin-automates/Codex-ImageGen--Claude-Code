{
  "name": "imagegen-mcp",
  "version": "0.1.0",
  "private": true,
  "description": "MCP server for the imagegen Claude Code plugin. Delegates to OpenAI Codex CLI.",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "build": "esbuild src/index.ts --bundle --platform=node --target=node18 --format=cjs --outfile=dist/index.cjs --legal-comments=none --minify --sourcemap=inline",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "~1.0.4",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "esbuild": "~0.24.0",
    "typescript": "^5.5.0",
    "vitest": "^1.6.0"
  }
}
